{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "const": "text"
        },
        "content": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "newline": {
          "default": true,
          "description": "Start a new line before printing the text",
          "type": "boolean"
        },
        "clear": {
          "default": true,
          "description": "Clear existing text before printing the text",
          "type": "boolean"
        },
        "skippable": {
          "default": true,
          "description": "Whether the text can be skipped.",
          "type": "boolean"
        }
      },
      "required": [
        "command",
        "content",
        "newline",
        "clear",
        "skippable"
      ],
      "additionalProperties": false,
      "description": "Display text"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "const": "textClear"
        }
      },
      "required": [
        "command"
      ],
      "additionalProperties": false,
      "description": "Clear text box"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "const": "textBox"
        },
        "position": {
          "description": "x, y coordinates of the text box",
          "minItems": 2,
          "maxItems": 2,
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "printMode": {
          "description": "Text printing mode",
          "type": "string",
          "enum": [
            "instant",
            "typewriter",
            "printer"
          ]
        },
        "printSpeed": {
          "description": "Speed of text printing, characters per second for typewriter, lines per second for printer",
          "type": "number"
        },
        "fillColor": {
          "description": "Text color",
          "type": "string"
        },
        "lineHeight": {
          "description": "Line height multiplier",
          "type": "number"
        },
        "indent": {
          "description": "Indentation in pixels for the first line of each paragraph",
          "type": "number"
        },
        "stroke": {
          "description": "Whether to apply stroke to text",
          "type": "boolean"
        },
        "shadow": {
          "description": "Whether to apply shadow to text",
          "type": "boolean"
        },
        "strokeColor": {
          "description": "Stroke color",
          "type": "string"
        },
        "strokeWidth": {
          "description": "Stroke width in pixels",
          "type": "number"
        },
        "shadowColor": {
          "description": "Shadow color",
          "type": "string"
        },
        "shadowOffsetX": {
          "description": "Shadow offset X in pixels",
          "type": "number"
        },
        "shadowOffsetY": {
          "description": "Shadow offset Y in pixels",
          "type": "number"
        },
        "shadowBlur": {
          "description": "Shadow blur radius in pixels",
          "type": "number"
        },
        "shadowWidth": {
          "description": "Shadow width in pixels, only effective when shadow is true",
          "type": "number"
        }
      },
      "required": [
        "command"
      ],
      "additionalProperties": false,
      "description": "Configure text box"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "const": "textBoxShow"
        }
      },
      "required": [
        "command"
      ],
      "additionalProperties": false,
      "description": "Show text box"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "const": "textBoxHide"
        }
      },
      "required": [
        "command"
      ],
      "additionalProperties": false,
      "description": "Hide text box"
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "const": "bgm"
        },
        "src": {
          "type": "string",
          "description": "Asset path"
        },
        "loop": {
          "default": true,
          "description": "Whether to loop the music, default is true",
          "type": "boolean"
        },
        "volume": {
          "default": 1,
          "description": "Volume of the music, ranges from 0 to 1, default is 1",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "fadeTime": {
          "default": 600,
          "description": "Fade time in milliseconds when starting the music",
          "type": "number"
        }
      },
      "required": [
        "command",
        "src",
        "loop",
        "volume",
        "fadeTime"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "command": {
          "type": "string",
          "const": "bgmStop"
        },
        "fadeTime": {
          "default": 600,
